apiVersion: v1
kind: Secret
metadata:
  name: task-management-secret
  namespace: tasks
type: Opaque
stringData:
  # PostgreSQL connection credentials
  # Replace these values with your actual credentials
  POSTGRES_USER: "your-postgres-username"
  POSTGRES_PASSWORD: "your-secure-password"
  POSTGRES_DB: "taskdb"
  
  # PostgreSQL host - adjust if using external database
  # For in-cluster PostgreSQL: postgres.postgres.svc.cluster.local
  # For external database: your-db-host.example.com
  POSTGRES_HOST: "postgres.postgres.svc.cluster.local"
  POSTGRES_PORT: "5432"
